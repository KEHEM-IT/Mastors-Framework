{
  "name": "@mastors/plugin-vite",
  "version": "0.1.0",
  "description": "Vite plugin for Mastors — incremental build-time CSS compilation with HMR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mastors/types": "workspace:*",
    "@mastors/compiler": "workspace:*",
    "@mastors/api": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}

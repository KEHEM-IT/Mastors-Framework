{
  "name": "@mastors/types",
  "version": "0.1.0",
  "description": "Core TypeScript type definitions for Mastors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.json --no-splitting",
    "dev": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.json --no-splitting --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}

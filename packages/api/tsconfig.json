{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@mastors/types":    ["../types/dist/index.d.ts"],
      "@mastors/tokens":   ["../tokens/dist/index.d.ts"],
      "@mastors/schemas":  ["../schemas/dist/index.d.ts"],
      "@mastors/core":     ["../core/dist/index.d.ts"],
      "@mastors/compiler": ["../compiler/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "dist", "node_modules"],
  "references": [
    { "path": "../types" },
    { "path": "../tokens" },
    { "path": "../schemas" },
    { "path": "../core" },
    { "path": "../compiler" }
  ]
}

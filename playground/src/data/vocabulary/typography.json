{
  "id": "typography",
  "label": "Typography",
  "icon": "fa-solid fa-font",
  "description": "Semantic text styles mapped to type-scale tokens for consistent typographic hierarchy.",
  "intents": [
    {
      "id": "heading.hero",
      "label": "Hero Heading",
      "shortLabel": "heading.hero",
      "description": "Largest display heading for hero sections and page-level titles. Maps to the H1 element.",
      "semanticRole": "heading",
      "htmlTag": "h1",
      "ariaRole": "heading",
      "ariaLandmark": false,
      "status": "stable",
      "since": "0.1.0",
      "mastors": {
        "declaration": "<h1 intent=\"heading.hero\">\n  Intent-Based Styling for the Future Web\n</h1>",
        "config": "// mastors.config.ts\nexport default defineConfig({\n  vocabulary: [\n    'heading.hero'\n  ]\n});",
        "description": "Maps to H1. Mastors resolves 5xl font-size, bold weight, tight line-height and tracking from tokens. The resolver emits a warning if a second heading.hero is declared on the same page."
      },
      "preview": { "type": "heading", "tag": "h1", "text": "Intent-Based Styling for the Future Web" },
      "cssProperties": ["font-size","font-weight","line-height","letter-spacing","color","font-family"],
      "tokenRefs": [
        { "property": "font-size",      "token": "token.font.size.5xl",         "description": "Display scale font size" },
        { "property": "font-weight",    "token": "token.font.weight.bold",      "description": "Bold weight for heroes" },
        { "property": "line-height",    "token": "token.font.lineHeight.tight",  "description": "Tight leading for large text" },
        { "property": "letter-spacing", "token": "token.font.tracking.tight",   "description": "Slightly tighter tracking" },
        { "property": "color",          "token": "token.color.text.default",    "description": "Primary text colour" }
      ],
      "a11y": {
        "wcagLevel": "AA",
        "wcagCriteria": [
          { "id": "1.3.1", "name": "Info and Relationships", "level": "A"  },
          { "id": "1.4.3", "name": "Contrast (Minimum)",     "level": "AA" },
          { "id": "2.4.6", "name": "Headings and Labels",    "level": "AA" }
        ],
        "ariaAttributes": ["aria-level=\"1\""],
        "focusable": false,
        "notes": [
          "Only one H1 per page — the resolver emits a warning if a second heading.hero is declared.",
          "Ensure heading text contrast meets 4.5:1 at all sizes (even large).",
          "Heading must describe the page topic — do not use for decorative text."
        ],
        "hints": []
      },
      "variants": [],
      "modifiers": [],
      "relatedIntents": ["heading.section","heading.subsection"]
    },
    {
      "id": "heading.section",
      "label": "Section Heading",
      "shortLabel": "heading.section",
      "description": "Second-level heading dividing major page sections. Maps to H2.",
      "semanticRole": "heading",
      "htmlTag": "h2",
      "ariaRole": "heading",
      "ariaLandmark": false,
      "status": "stable",
      "since": "0.1.0",
      "mastors": {
        "declaration": "<h2 intent=\"heading.section\">\n  Design Intent, Not Classes\n</h2>",
        "config": "// mastors.config.ts\nexport default defineConfig({\n  vocabulary: [\n    'heading.section'\n  ]\n});",
        "description": "Maps to H2. Resolves 3xl size, bold weight, and snug line-height. Used to divide major page sections. Heading hierarchy is validated by the resolver."
      },
      "preview": { "type": "heading", "tag": "h2", "text": "Design Intent, Not Classes" },
      "cssProperties": ["font-size","font-weight","line-height","letter-spacing","color"],
      "tokenRefs": [
        { "property": "font-size",   "token": "token.font.size.3xl",        "description": "Section-level size" },
        { "property": "font-weight", "token": "token.font.weight.bold",     "description": "Bold section label" },
        { "property": "line-height", "token": "token.font.lineHeight.snug", "description": "Comfortable leading" },
        { "property": "color",       "token": "token.color.text.default",   "description": "Primary text colour" }
      ],
      "a11y": {
        "wcagLevel": "AA",
        "wcagCriteria": [
          { "id": "1.3.1", "name": "Info and Relationships", "level": "A"  },
          { "id": "2.4.6", "name": "Headings and Labels",    "level": "AA" }
        ],
        "ariaAttributes": ["aria-level=\"2\""],
        "focusable": false,
        "notes": [
          "Heading hierarchy must be sequential — do not skip from H1 to H3.",
          "Section headings help screen-reader users navigate via the heading list (JAWS, NVDA, VoiceOver)."
        ],
        "hints": []
      },
      "variants": [],
      "modifiers": [],
      "relatedIntents": ["heading.hero","heading.subsection"]
    },
    {
      "id": "heading.subsection",
      "label": "Subsection Heading",
      "shortLabel": "heading.subsection",
      "description": "Third-level heading for sub-sections within a major section. Maps to H3.",
      "semanticRole": "heading",
      "htmlTag": "h3",
      "ariaRole": "heading",
      "ariaLandmark": false,
      "status": "stable",
      "since": "0.1.0",
      "mastors": {
        "declaration": "<h3 intent=\"heading.subsection\">\n  Automatic accessibility enforcement\n</h3>",
        "config": "// mastors.config.ts\nexport default defineConfig({\n  vocabulary: [\n    'heading.subsection'\n  ]\n});",
        "description": "Maps to H3. Resolves xl size, semibold weight and normal line-height. Must nest inside an H2 section — the resolver validates heading depth."
      },
      "preview": { "type": "heading", "tag": "h3", "text": "Automatic accessibility enforcement" },
      "cssProperties": ["font-size","font-weight","line-height","color"],
      "tokenRefs": [
        { "property": "font-size",   "token": "token.font.size.xl",           "description": "Subsection size" },
        { "property": "font-weight", "token": "token.font.weight.semibold",   "description": "Semibold for visual hierarchy" },
        { "property": "line-height", "token": "token.font.lineHeight.normal", "description": "Normal leading" },
        { "property": "color",       "token": "token.color.text.default",     "description": "Primary text colour" }
      ],
      "a11y": {
        "wcagLevel": "AA",
        "wcagCriteria": [
          { "id": "1.3.1", "name": "Info and Relationships", "level": "A"  },
          { "id": "2.4.6", "name": "Headings and Labels",    "level": "AA" }
        ],
        "ariaAttributes": ["aria-level=\"3\""],
        "focusable": false,
        "notes": [
          "Maintain heading level sequence — H3 must nest inside H2 sections.",
          "Avoid using heading styles purely for visual emphasis — use bold/italic instead."
        ],
        "hints": []
      },
      "variants": [],
      "modifiers": [],
      "relatedIntents": ["heading.hero","heading.section"]
    },
    {
      "id": "body.readable",
      "label": "Readable Body",
      "shortLabel": "body.readable",
      "description": "Standard body copy optimised for screen readability. Comfortable line-height and measure.",
      "semanticRole": "paragraph",
      "htmlTag": "p",
      "ariaRole": null,
      "ariaLandmark": false,
      "status": "stable",
      "since": "0.1.0",
      "mastors": {
        "declaration": "<p intent=\"body.readable\">\n  Mastors resolves semantic design intent into accessible,\n  responsive, theme-aware CSS at build time.\n</p>",
        "config": "// mastors.config.ts\nexport default defineConfig({\n  vocabulary: [\n    'body.readable'\n  ]\n});",
        "description": "Resolves base font-size (16px), relaxed line-height (1.6) and an optimal readable max-width (~65ch) from tokens. Suitable for interface body copy."
      },
      "preview": { "type": "body", "tag": "p", "text": "Mastors resolves semantic design intent into accessible, responsive, theme-aware CSS at build time — with zero runtime overhead." },
      "cssProperties": ["font-size","line-height","color","max-width","font-family"],
      "tokenRefs": [
        { "property": "font-size",   "token": "token.font.size.base",          "description": "Base body size (16px)" },
        { "property": "line-height", "token": "token.font.lineHeight.relaxed", "description": "Relaxed leading for readability" },
        { "property": "color",       "token": "token.color.text.default",      "description": "Primary text colour" },
        { "property": "max-width",   "token": "token.measure.readable",        "description": "~65 ch optimal line length" }
      ],
      "a11y": {
        "wcagLevel": "AA",
        "wcagCriteria": [
          { "id": "1.4.3",  "name": "Contrast (Minimum)",  "level": "AA"  },
          { "id": "1.4.8",  "name": "Visual Presentation", "level": "AAA" },
          { "id": "1.4.12", "name": "Text Spacing",        "level": "AA"  }
        ],
        "ariaAttributes": [],
        "focusable": false,
        "notes": [
          "Line-height (leading) must be at least 1.5 times the font size (WCAG 1.4.12).",
          "Optimal line length is 45–75 characters. max-width token enforces this automatically.",
          "Text must reflow to a single column at 400% zoom without horizontal scroll (WCAG 1.4.10)."
        ],
        "hints": []
      },
      "variants": ["longform"],
      "modifiers": [],
      "relatedIntents": ["body.readable.longform"]
    },
    {
      "id": "body.readable.longform",
      "label": "Longform Body",
      "shortLabel": "body.readable.longform",
      "description": "Extended body copy for articles, documentation, and prose-heavy content. Wider measure, slightly larger size.",
      "semanticRole": "paragraph",
      "htmlTag": "p",
      "ariaRole": null,
      "ariaLandmark": false,
      "status": "stable",
      "since": "0.1.0",
      "mastors": {
        "declaration": "<article>\n  <h2 intent=\"heading.section\">Article Title</h2>\n  <p intent=\"body.readable.longform\">\n    Extended prose content for documentation or articles.\n  </p>\n</article>",
        "config": "// mastors.config.ts\nexport default defineConfig({\n  vocabulary: [\n    'body.readable.longform'\n  ]\n});",
        "description": "Resolves md font-size, loose line-height (1.8) and a wider max-width (~75ch). Wrap in <article> with a visible heading for assistive technology navigation."
      },
      "preview": { "type": "body", "tag": "p", "text": "Mastors resolves semantic design intent into accessible, responsive, theme-aware CSS at build time — with zero runtime overhead. Longform body adds generous spacing and wider measure for sustained reading." },
      "cssProperties": ["font-size","line-height","color","max-width","font-family","word-spacing"],
      "tokenRefs": [
        { "property": "font-size",   "token": "token.font.size.md",          "description": "Slightly larger for long-read" },
        { "property": "line-height", "token": "token.font.lineHeight.loose",  "description": "Loose leading for long prose" },
        { "property": "color",       "token": "token.color.text.default",     "description": "Primary text colour" },
        { "property": "max-width",   "token": "token.measure.longform",       "description": "~75 ch for longform measure" }
      ],
      "a11y": {
        "wcagLevel": "AAA",
        "wcagCriteria": [
          { "id": "1.4.3",  "name": "Contrast (Minimum)",  "level": "AA"  },
          { "id": "1.4.8",  "name": "Visual Presentation", "level": "AAA" },
          { "id": "1.4.12", "name": "Text Spacing",        "level": "AA"  }
        ],
        "ariaAttributes": [],
        "focusable": false,
        "notes": [
          "For articles, wrap in <article> with a visible heading for assistive technology navigation.",
          "Avoid justified text — it creates uneven spacing that hinders readability (WCAG 1.4.8).",
          "Consider offering a user control to increase text size or spacing without loss of content."
        ],
        "hints": []
      },
      "variants": [],
      "modifiers": [],
      "relatedIntents": ["body.readable"]
    }
  ]
}
